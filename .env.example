# ============================================================
# LOCAL DEVELOPMENT ONLY — copy this to .env and fill in values
# On Vercel, set these as Environment Variables in the dashboard
# (Settings → Environment Variables), not in this file.
# ============================================================

# Supabase connection string (get from Supabase → Settings → Database → Connection string → URI)
# Use the "Session mode" pooler URL for serverless (port 5432):
#   postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:5432/postgres
# Leave blank to use local SQLite (for local dev/testing only)
DATABASE_URL=

# HubSpot Private App token (Settings → Integrations → Private Apps)
HUBSPOT_PRIVATE_APP_TOKEN=

# Aircall API credentials (Aircall Dashboard → Integrations → API Keys)
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
